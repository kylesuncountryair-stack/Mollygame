generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  ADMIN
}

enum QuestionType {
  DAILY
  WEEKLY
}

enum TransactionType {
  QUESTION_CORRECT
  ADMIN_GRANT
  ADMIN_ADJUST
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  passwordSalt String
  role         Role     @default(PLAYER)
  createdAt    DateTime @default(now())
  // Self-service avatar customization (Profile page). avatarColor is a key
  // into the palette in src/components/Avatar.tsx; avatarIcon is either
  // "initials" (default), "letter", or one of the 10 icon keys. Both are
  // nullable so existing accounts fall back to the old deterministic look.
  avatarColor  String?
  avatarIcon   String?

  answers             Answer[]
  logTransactions     LogTransaction[] @relation("PlayerTransactions")
  issuedTransactions  LogTransaction[] @relation("IssuedByAdmin")
  following           Follow[]         @relation("Follower")
  followedBy          Follow[]         @relation("Following")
}

model Question {
  id           String       @id @default(cuid())
  type         QuestionType
  prompt       String
  options      Json
  correctIndex Int
  logsReward   Int          @default(1)
  activeDate   DateTime
  createdAt    DateTime     @default(now())

  answers Answer[]

  @@index([type, activeDate])
}

model Answer {
  id            String   @id @default(cuid())
  userId        String
  questionId    String
  selectedIndex Int
  isCorrect     Boolean
  logsAwarded   Int
  answeredAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model LogTransaction {
  id         String          @id @default(cuid())
  userId     String
  amount     Int
  reason     String
  type       TransactionType
  issuedById String?
  createdAt  DateTime        @default(now())

  user     User  @relation("PlayerTransactions", fields: [userId], references: [id], onDelete: Cascade)
  issuedBy User? @relation("IssuedByAdmin", fields: [issuedById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

// A player following another player just to watch their rank on a small,
// friendlier "mini leaderboard" on the dashboard. One-directional and
// doesn't require the other person's approval — low stakes, internal game.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}
